{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TestGeneratorInput",
  "description": "Input contract for the test generator agent. Reads profile from catalog/tables/ and migration output from migrator artifacts.",
  "type": "object",
  "required": ["schema_version", "run_id", "items"],
  "properties": {
    "schema_version": { "type": "string", "const": "2.0" },
    "run_id": { "type": "string", "format": "uuid" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["item_id", "selected_writer"],
        "properties": {
          "item_id": { "type": "string", "description": "Fully qualified table name: <schema>.<table>." },
          "selected_writer": { "type": "string", "description": "Fully qualified procedure name selected by scoping agent." }
        }
      },
      "minItems": 1
    }
  }
}
