{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ScopeInput",
  "description": "Input contract for the scoping agent. Maps target tables to candidate writer procedures.",
  "type": "object",
  "required": ["schema_version", "run_id", "project_root", "items"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "run_id": { "type": "string", "format": "uuid" },
    "project_root": {
      "type": "string",
      "description": "Absolute path to the project root directory (contains ddl/, catalog/, manifest.json)."
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["item_id"],
        "properties": {
          "item_id": { "type": "string", "description": "Fully qualified table name: <schema>.<table>." },
          "search_depth": {
            "type": "integer",
            "minimum": 0,
            "maximum": 5,
            "default": 2,
            "description": "Maximum call-graph traversal depth from discovered candidate procedures."
          }
        }
      },
      "minItems": 1
    }
  }
}
