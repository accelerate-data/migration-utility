{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ExtractionManifest",
  "description": "Manifest written by setup-ddl at extraction time. Downstream tools read this to auto-select dialect and delimiter instead of hardcoding tsql.",
  "type": "object",
  "required": ["schema_version", "technology", "dialect", "source_database", "extracted_schemas", "extracted_at"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "technology": {
      "type": "string",
      "enum": ["sql_server", "fabric_warehouse", "fabric_lakehouse", "snowflake"],
      "description": "Source technology that produced this DDL extraction."
    },
    "dialect": {
      "type": "string",
      "enum": ["tsql", "spark", "snowflake"],
      "description": "sqlglot dialect for parsing the extracted DDL files."
    },
    "source_database": {
      "type": "string",
      "description": "Name of the source database."
    },
    "extracted_schemas": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of schemas included in the extraction."
    },
    "extracted_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of extraction."
    },
    "sandbox": {
      "type": "object",
      "properties": {
        "run_id": { "type": "string" },
        "database": { "type": "string" }
      },
      "required": ["run_id", "database"],
      "additionalProperties": false
    }
  }
}
