{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FixtureManifest",
  "description": "Output contract for the test generator agent. Contains per-item branch-covering unit test fixtures with ground truth from proc execution.",
  "type": "object",
  "required": ["schema_version", "run_id", "results", "summary"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "run_id": { "type": "string", "format": "uuid" },
    "results": {
      "type": "array",
      "items": { "$ref": "#/$defs/fixture_result" }
    },
    "summary": { "$ref": "common.json#/$defs/summary_section" }
  },
  "$defs": {
    "fixture_result": {
      "type": "object",
      "required": ["item_id", "status", "coverage", "unit_tests", "warnings", "validation", "errors"],
      "properties": {
        "item_id": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["ok", "partial", "error"]
        },
        "coverage": {
          "type": "string",
          "enum": ["complete", "partial"]
        },
        "branch_manifest": {
          "type": "array",
          "description": "All branches identified in the proc. Each branch maps to one or more test scenarios.",
          "items": { "$ref": "#/$defs/branch_entry" }
        },
        "unit_tests": {
          "type": "array",
          "items": { "$ref": "#/$defs/unit_test" }
        },
        "uncovered_branches": {
          "type": "array",
          "description": "Empty when coverage is complete; non-empty when coverage is partial.",
          "items": { "type": "string", "description": "Branch id from branch_manifest." }
        },
        "warnings": {
          "type": "array",
          "items": { "$ref": "common.json#/$defs/diagnostics_entry" }
        },
        "validation": { "$ref": "common.json#/$defs/validation_section" },
        "errors": {
          "type": "array",
          "items": { "$ref": "common.json#/$defs/diagnostics_entry" }
        }
      }
    },
    "branch_entry": {
      "type": "object",
      "required": ["id", "description", "scenarios"],
      "properties": {
        "id": { "type": "string", "description": "Stable branch identifier, e.g. merge_matched_update." },
        "statement_index": { "type": "integer", "description": "Index into the resolved statements array." },
        "description": { "type": "string", "description": "Human-readable branch description." },
        "scenarios": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Test names from unit_tests[] that exercise this branch."
        }
      }
    },
    "unit_test": {
      "type": "object",
      "required": ["name", "model", "given", "expect"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Test name — convention: test_<load_pattern>_<scenario_description>."
        },
        "model": {
          "type": "string",
          "description": "dbt model name, deterministic from table FQN."
        },
        "given": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["input", "rows"],
            "properties": {
              "input": {
                "type": "string",
                "description": "dbt ref() or source() expression identifying the mocked relation."
              },
              "rows": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "object" },
                "description": "Synthetic fixture input rows as column-value maps."
              }
            }
          }
        },
        "expect": {
          "type": "object",
          "required": ["rows"],
          "properties": {
            "rows": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "object" },
              "description": "Ground truth output rows captured from proc execution."
            }
          }
        }
      }
    }
  }
}
