{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TableCatalog",
  "description": "Per-table catalog file produced by setup-ddl. Contains catalog signals and inbound references.",
  "type": "object",
  "required": [
    "schema",
    "name",
    "primary_keys",
    "unique_indexes",
    "foreign_keys",
    "auto_increment_columns",
    "referenced_by"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "description": "Schema name, e.g. silver"
    },
    "name": {
      "type": "string",
      "description": "Object name, e.g. DimCustomer"
    },
    "ddl_hash": {
      "type": "string",
      "description": "SHA-256 of normalized source DDL. Used for diff-aware reexport."
    },
    "stale": {
      "type": "boolean",
      "description": "True when the object was present in a prior extraction but absent in the latest."
    },
    "excluded": {
      "type": "boolean",
      "description": "When true, the object is excluded from the migration pipeline and skipped by batch scheduling."
    },
    "columns": {
      "type": "array",
      "description": "Column definitions from sys.columns.",
      "items": {
        "type": "object",
        "required": [
          "name",
          "sql_type",
          "is_nullable",
          "is_identity"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "sql_type": {
            "type": "string",
            "description": "Formatted SQL type, e.g. NVARCHAR(50), BIGINT"
          },
          "is_nullable": {
            "type": "boolean"
          },
          "is_identity": {
            "type": "boolean"
          }
        }
      }
    },
    "primary_keys": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "constraint_name",
          "columns"
        ],
        "properties": {
          "constraint_name": {
            "type": "string"
          },
          "columns": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "unique_indexes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "index_name",
          "columns"
        ],
        "properties": {
          "index_name": {
            "type": "string"
          },
          "columns": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "foreign_keys": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "constraint_name",
          "columns",
          "referenced_schema",
          "referenced_table",
          "referenced_columns"
        ],
        "properties": {
          "constraint_name": {
            "type": "string"
          },
          "columns": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "referenced_schema": {
            "type": "string"
          },
          "referenced_table": {
            "type": "string"
          },
          "referenced_columns": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "auto_increment_columns": {
      "type": "array",
      "description": "Columns with automatic sequence generation. Normalized from identity (SQL Server), autoincrement (Snowflake), or generated always (Spark).",
      "items": {
        "type": "object",
        "required": [
          "column"
        ],
        "properties": {
          "column": {
            "type": "string"
          },
          "seed": {
            "type": "integer"
          },
          "increment": {
            "type": "integer"
          },
          "mechanism": {
            "type": "string",
            "enum": [
              "identity",
              "autoincrement",
              "sequence",
              "generated_always"
            ],
            "description": "Source mechanism. Informational only \u2014 downstream agents use presence/absence, not mechanism."
          }
        }
      }
    },
    "change_capture": {
      "type": "object",
      "description": "Change-tracking metadata. Optional \u2014 absent means not detected or not applicable.",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "mechanism": {
          "type": "string",
          "enum": [
            "cdc",
            "change_tracking",
            "stream",
            "change_data_feed"
          ],
          "description": "Source mechanism: cdc/change_tracking (SQL Server), stream (Snowflake), change_data_feed (Delta/Spark)."
        }
      }
    },
    "sensitivity_classifications": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "column",
          "label",
          "information_type"
        ],
        "properties": {
          "column": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "information_type": {
            "type": "string"
          }
        }
      }
    },
    "technology_metadata": {
      "type": "object",
      "description": "Technology-specific metadata with no cross-platform equivalent. Keyed by technology name. Downstream agents may inspect but must not require.",
      "additionalProperties": true
    },
    "referenced_by": {
      "$ref": "#/$defs/reference_groups"
    },
    "profile": {
      "description": "Written by the /profiling-table skill or profiler agent. Not present after setup-ddl, only after profiling.",
      "$ref": "#/$defs/profile_section"
    },
    "refactor": {
      "type": "object",
      "description": "Refactoring results written by the /refactoring-sql skill. Not present until after refactoring.",
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "ok",
            "partial",
            "error"
          ]
        },
        "extracted_sql": {
          "type": "string",
          "description": "Pure SELECT equivalent of the procedure's write operation."
        },
        "refactored_sql": {
          "type": "string",
          "description": "CTE-structured SELECT ready for dbt model generation."
        },
        "semantic_review": {
          "$ref": "common.json#/$defs/refactor_semantic_review"
        },
        "compare_sql": {
          "$ref": "common.json#/$defs/refactor_compare_sql_summary"
        },
        "warnings": {
          "type": "array",
          "items": {
            "$ref": "common.json#/$defs/diagnostics_entry"
          }
        },
        "errors": {
          "type": "array",
          "items": {
            "$ref": "common.json#/$defs/diagnostics_entry"
          }
        }
      }
    },
    "test_gen": {
      "type": "object",
      "description": "Test generation summary written by test-harness write. Not present until after test generation.",
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["ok", "error"]
        },
        "test_spec_path": {
          "type": "string",
          "description": "Relative path to the test-spec JSON file, e.g. test-specs/silver.dimcustomer.json"
        },
        "branches": {
          "type": "integer",
          "description": "Number of test branches in the test spec."
        },
        "unit_tests": {
          "type": "integer",
          "description": "Number of unit tests in the test spec."
        },
        "coverage": {
          "type": "string",
          "enum": ["complete", "partial", "none"],
          "description": "Branch coverage level."
        },
        "warnings": {
          "type": "array",
          "items": { "$ref": "common.json#/$defs/diagnostics_entry" }
        },
        "errors": {
          "type": "array",
          "items": { "$ref": "common.json#/$defs/diagnostics_entry" }
        }
      }
    },
    "generate": {
      "type": "object",
      "description": "dbt model generation summary written by migrate write. Not present until after model generation.",
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["ok", "error"]
        },
        "model_path": {
          "type": "string",
          "description": "Relative path to the generated dbt model SQL file."
        },
        "schema_yml": {
          "type": "boolean",
          "description": "Whether a schema YAML entry exists for this model."
        },
        "compiled": {
          "type": "boolean",
          "description": "Whether dbt compile succeeded for this model."
        },
        "tests_passed": {
          "type": "boolean",
          "description": "Whether dbt test passed for this model."
        },
        "test_count": {
          "type": "integer",
          "description": "Number of dbt tests executed."
        },
        "warnings": {
          "type": "array",
          "items": { "$ref": "common.json#/$defs/diagnostics_entry" }
        },
        "errors": {
          "type": "array",
          "items": { "$ref": "common.json#/$defs/diagnostics_entry" }
        }
      }
    },
    "is_source": {
      "type": "boolean",
      "description": "When true, this table is a dbt source reference \u2014 excluded from the migration pipeline and included in sources.yml. Set by discover write-source or confirmed during /init-dbt."
    },
    "scoping": {
      "type": "object",
      "description": "Writer selection results from scoping agent or /analyzing-table. Written by discover write-scoping.",
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "resolved",
            "ambiguous_multi_writer",
            "no_writer_found",
            "error"
          ]
        },
        "selected_writer": {
          "type": "string",
          "description": "Normalized FQN of the selected writer procedure. Present only when status is resolved."
        },
        "selected_writer_rationale": {
          "type": "string",
          "description": "LLM reasoning for why this writer was selected over alternatives (or why ambiguous/no_writer_found)."
        },
        "candidates": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "procedure_name",
              "rationale"
            ],
            "properties": {
              "procedure_name": {
                "type": "string"
              },
              "dependencies": {
                "type": "object",
                "properties": {
                  "tables": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "views": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "functions": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              },
              "rationale": {
                "type": "string"
              }
            }
          }
        },
        "warnings": {
          "type": "array",
          "items": {
            "$ref": "common.json#/$defs/diagnostics_entry"
          }
        },
        "errors": {
          "type": "array",
          "items": {
            "$ref": "common.json#/$defs/diagnostics_entry"
          }
        }
      }
    }
  },
  "$defs": {
    "reference_groups": {
      "type": "object",
      "description": "Inbound references grouped by object type. Each type splits into in_scope and out_of_scope.",
      "required": [
        "procedures",
        "views",
        "functions"
      ],
      "properties": {
        "procedures": {
          "$ref": "common.json#/$defs/scoped_ref_list"
        },
        "views": {
          "$ref": "common.json#/$defs/scoped_ref_list"
        },
        "functions": {
          "$ref": "common.json#/$defs/scoped_ref_list"
        }
      }
    },
    "profile_section": {
      "type": "object",
      "required": [
        "status",
        "writer"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "ok",
            "partial",
            "error"
          ]
        },
        "writer": {
          "type": "string"
        },
        "classification": {
          "type": "object",
          "properties": {
            "resolved_kind": {
              "type": "string",
              "enum": [
                "dim_non_scd",
                "dim_scd1",
                "dim_scd2",
                "dim_junk",
                "fact_transaction",
                "fact_periodic_snapshot",
                "fact_accumulating_snapshot",
                "fact_aggregate"
              ]
            },
            "rationale": {
              "type": "string"
            },
            "source": {
              "type": "string",
              "enum": [
                "catalog",
                "llm",
                "catalog+llm"
              ]
            }
          }
        },
        "primary_key": {
          "type": "object",
          "properties": {
            "columns": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "primary_key_type": {
              "type": "string",
              "enum": [
                "surrogate",
                "natural",
                "composite",
                "unknown"
              ]
            },
            "rationale": {
              "type": "string",
              "description": "Why these columns were identified as the primary key and why this PK type."
            },
            "source": {
              "type": "string",
              "enum": [
                "catalog",
                "llm",
                "catalog+llm"
              ]
            }
          }
        },
        "natural_key": {
          "type": "object",
          "properties": {
            "columns": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "rationale": {
              "type": "string"
            },
            "source": {
              "type": "string",
              "enum": [
                "catalog",
                "llm",
                "catalog+llm"
              ]
            }
          }
        },
        "watermark": {
          "type": "object",
          "properties": {
            "column": {
              "type": [
                "string",
                "null"
              ]
            },
            "rationale": {
              "type": "string"
            },
            "source": {
              "type": "string",
              "enum": [
                "catalog",
                "llm",
                "catalog+llm"
              ]
            }
          }
        },
        "foreign_keys": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "column": {
                "type": "string"
              },
              "references_source_relation": {
                "type": "string"
              },
              "references_column": {
                "type": "string"
              },
              "fk_type": {
                "type": "string",
                "enum": [
                  "standard",
                  "role_playing",
                  "degenerate"
                ]
              },
              "rationale": {
                "type": "string",
                "description": "Why this FK type was chosen (standard vs role_playing vs degenerate)."
              },
              "source": {
                "type": "string",
                "enum": [
                  "catalog",
                  "llm",
                  "catalog+llm"
                ]
              }
            }
          }
        },
        "pii_actions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "column": {
                "type": "string"
              },
              "entity": {
                "type": "string"
              },
              "suggested_action": {
                "type": "string",
                "enum": [
                  "mask",
                  "drop",
                  "tokenize",
                  "keep"
                ]
              },
              "rationale": {
                "type": "string",
                "description": "Why this PII action was suggested for this column."
              },
              "source": {
                "type": "string",
                "enum": [
                  "catalog",
                  "llm",
                  "catalog+llm"
                ]
              }
            }
          }
        },
        "warnings": {
          "type": "array",
          "items": {
            "$ref": "common.json#/$defs/diagnostics_entry"
          }
        },
        "errors": {
          "type": "array",
          "items": {
            "$ref": "common.json#/$defs/diagnostics_entry"
          }
        }
      }
    }
  }
}
