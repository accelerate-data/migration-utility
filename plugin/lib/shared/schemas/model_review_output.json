{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "model_review_output.json",
  "title": "ModelReviewOutput",
  "description": "Output contract for the /reviewing-model skill. Returned as JSON in the LLM response.",
  "type": "object",
  "required": ["item_id", "status", "checks", "feedback_for_model_generator", "warnings", "errors"],
  "properties": {
    "item_id": { "type": "string", "description": "Fully qualified table name: <schema>.<table>." },
    "status": {
      "type": "string",
      "enum": ["approved", "revision_requested", "approved_with_warnings", "error"]
    },
    "checks": {
      "type": "object",
      "required": ["standards", "correctness", "test_integration"],
      "properties": {
        "standards": { "$ref": "#/$defs/check_result" },
        "correctness": { "$ref": "#/$defs/check_result" },
        "test_integration": { "$ref": "#/$defs/check_result" }
      }
    },
    "feedback_for_model_generator": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "message", "severity", "ack_required"],
        "properties": {
          "code": { "type": "string", "description": "Stable machine-readable code from a reference file (e.g. SQL_001)." },
          "message": { "type": "string" },
          "severity": { "type": "string", "enum": ["error", "warning", "info"] },
          "ack_required": { "type": "boolean", "description": "true for error/warning; false for info." }
        },
        "additionalProperties": false
      }
    },
    "acknowledgements": {
      "type": "object",
      "description": "Present on resubmission only. Maps feedback code to 'fixed' or 'ignored: <reason>'.",
      "additionalProperties": { "type": "string" }
    },
    "warnings": {
      "type": "array",
      "items": { "$ref": "common.json#/$defs/diagnostics_entry" }
    },
    "errors": {
      "type": "array",
      "items": { "$ref": "common.json#/$defs/diagnostics_entry" }
    }
  },
  "$defs": {
    "check_result": {
      "type": "object",
      "required": ["passed", "issues"],
      "properties": {
        "passed": { "type": "boolean" },
        "issues": {
          "type": "array",
          "items": { "$ref": "common.json#/$defs/diagnostics_entry" }
        }
      }
    }
  }
}
