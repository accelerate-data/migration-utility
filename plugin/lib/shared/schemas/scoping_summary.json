{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ScopingSummary",
  "description": "Lightweight batch rollup from the scoping agent. Contains per-item status only — full scoping data lives in catalog/tables/<table>.json.",
  "type": "object",
  "required": ["schema_version", "run_id", "results", "summary"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "run_id": { "type": "string", "format": "uuid" },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["item_id", "status"],
        "properties": {
          "item_id": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["resolved", "ambiguous_multi_writer", "no_writer_found", "error"]
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "required": ["total", "resolved", "ambiguous_multi_writer", "no_writer_found", "error"],
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "resolved": { "type": "integer", "minimum": 0 },
        "ambiguous_multi_writer": { "type": "integer", "minimum": 0 },
        "no_writer_found": { "type": "integer", "minimum": 0 },
        "error": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
