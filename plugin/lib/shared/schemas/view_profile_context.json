{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "view_profile_context.json",
  "title": "ViewProfileContext",
  "description": "Output of `profile view-context`. View catalog data with object_type added to each in_scope entry. LLM uses sql_elements + logic_summary for classification and calls discover show on deps if needed.",
  "type": "object",
  "required": ["view", "is_materialized_view", "sql_elements", "logic_summary", "references", "referenced_by", "warnings", "errors"],
  "properties": {
    "view": { "type": "string", "description": "Normalized FQN of the target view." },
    "is_materialized_view": { "type": "boolean" },
    "sql_elements": {
      "type": ["array", "null"],
      "description": "SQLglot-extracted SQL features from scoping.sql_elements. Null if scoping had parse error.",
      "items": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["join", "aggregation", "window_function", "case", "subquery", "cte", "group_by"]
          },
          "detail": { "type": "string" }
        }
      }
    },
    "logic_summary": {
      "type": ["string", "null"],
      "description": "Plain-language description of what the view computes, from scoping.logic_summary."
    },
    "columns": {
      "type": "array",
      "description": "Column definitions. Present only for materialized views.",
      "items": {
        "type": "object",
        "required": ["name", "sql_type"],
        "properties": {
          "name": { "type": "string" },
          "sql_type": { "type": "string" },
          "is_nullable": { "type": "boolean" }
        }
      }
    },
    "references": {
      "type": "object",
      "description": "Outbound references from the view catalog, with object_type added to each in_scope entry.",
      "properties": {
        "tables": { "$ref": "#/$defs/enriched_ref_list" },
        "views": { "$ref": "#/$defs/enriched_ref_list" },
        "functions": { "$ref": "#/$defs/enriched_ref_list" }
      }
    },
    "referenced_by": {
      "type": "object",
      "description": "Inbound references from the view catalog, with object_type added to each in_scope entry.",
      "properties": {
        "procedures": { "$ref": "#/$defs/enriched_ref_list" },
        "views": { "$ref": "#/$defs/enriched_ref_list" },
        "functions": { "$ref": "#/$defs/enriched_ref_list" }
      }
    },
    "warnings": {
      "type": "array",
      "items": { "$ref": "common.json#/$defs/diagnostics_entry" }
    },
    "errors": {
      "type": "array",
      "items": { "$ref": "common.json#/$defs/diagnostics_entry" }
    }
  },
  "$defs": {
    "enriched_ref_list": {
      "type": "object",
      "required": ["in_scope", "out_of_scope"],
      "properties": {
        "in_scope": {
          "type": "array",
          "items": {
            "allOf": [
              { "$ref": "common.json#/$defs/in_scope_ref" },
              {
                "properties": {
                  "object_type": {
                    "type": "string",
                    "enum": ["table", "view", "function", "procedure"],
                    "description": "Type of the referenced object. Derived from the bucket it appears in."
                  }
                }
              }
            ]
          }
        },
        "out_of_scope": {
          "type": "array",
          "items": { "$ref": "common.json#/$defs/out_of_scope_ref" }
        }
      }
    }
  }
}
