{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "sandbox_up_output.json",
  "title": "SandboxUpOutput",
  "description": "Output of the test-harness sandbox-up command — sandbox creation and schema cloning result.",
  "type": "object",
  "required": ["sandbox_database", "status", "tables_cloned", "procedures_cloned", "errors"],
  "properties": {
    "sandbox_database": { "type": "string" },
    "status": { "type": "string", "enum": ["ok", "partial", "error"] },
    "tables_cloned": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Fully qualified table names cloned into the sandbox."
    },
    "procedures_cloned": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Fully qualified procedure names cloned into the sandbox."
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "message"],
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" }
        }
      }
    }
  }
}
