{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "test_review_output.json",
  "title": "TestReviewOutput",
  "description": "Output contract for the /reviewing-tests skill. Returned as JSON in the LLM response.",
  "type": "object",
  "required": ["item_id", "status", "reviewer_branch_manifest", "coverage", "quality_issues", "feedback_for_generator", "warnings", "errors"],
  "properties": {
    "item_id": { "type": "string", "description": "Fully qualified table name: <schema>.<table>." },
    "status": {
      "type": "string",
      "enum": ["approved", "approved_with_warnings", "revision_requested", "error"]
    },
    "reviewer_branch_manifest": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description", "covered", "covering_scenarios"],
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" },
          "covered": { "type": "boolean" },
          "covering_scenarios": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "coverage": {
      "type": "object",
      "required": ["total_branches", "covered_branches", "score", "uncovered"],
      "properties": {
        "total_branches": { "type": "integer", "minimum": 0 },
        "covered_branches": { "type": "integer", "minimum": 0 },
        "untestable_branches": { "type": "integer", "minimum": 0 },
        "score": { "type": "string", "enum": ["complete", "partial"] },
        "uncovered": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "description"],
            "properties": {
              "id": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "untestable": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "description", "rationale"],
            "properties": {
              "id": { "type": "string" },
              "description": { "type": "string" },
              "rationale": { "type": "string" }
            }
          }
        }
      }
    },
    "quality_issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["scenario", "issue", "severity"],
        "properties": {
          "scenario": { "type": "string" },
          "issue": { "type": "string" },
          "severity": { "type": "string", "enum": ["warning", "error"] }
        }
      }
    },
    "feedback_for_generator": {
      "type": "object",
      "required": ["uncovered_branches", "quality_fixes"],
      "properties": {
        "uncovered_branches": {
          "type": "array",
          "items": { "type": "string" }
        },
        "quality_fixes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": { "$ref": "common.json#/$defs/diagnostics_entry" }
    },
    "errors": {
      "type": "array",
      "items": { "$ref": "common.json#/$defs/diagnostics_entry" }
    }
  }
}
