{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "test_spec_output.json",
  "title": "TestSpecOutput",
  "description": "Batch output of the /generate-tests command — wraps per-item test specs with run metadata and summary.",
  "type": "object",
  "required": ["schema_version", "run_id", "results", "summary"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "run_id": { "type": "string" },
    "results": {
      "type": "array",
      "items": { "$ref": "test_spec.json" }
    },
    "summary": { "$ref": "common.json#/$defs/summary_section" }
  }
}
