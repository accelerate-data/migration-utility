{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DecompositionProposal",
  "description": "Output contract for the decomposer agent. Contains per-item SQL decomposition proposals with logical blocks and split points.",
  "type": "object",
  "required": ["schema_version", "run_id", "results", "summary"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "run_id": { "type": "string", "format": "uuid" },
    "results": {
      "type": "array",
      "items": { "$ref": "#/$defs/decomposition_result" }
    },
    "summary": { "$ref": "common.json#/$defs/summary_section" }
  },
  "$defs": {
    "decomposition_result": {
      "type": "object",
      "required": ["item_id", "status", "segmented_logical_blocks", "candidate_model_split_points", "warnings", "validation", "errors"],
      "properties": {
        "item_id": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["ok", "partial", "error"]
        },
        "segmented_logical_blocks": {
          "type": "array",
          "items": { "$ref": "#/$defs/logical_block" }
        },
        "candidate_model_split_points": {
          "type": "array",
          "items": { "$ref": "#/$defs/split_point" }
        },
        "warnings": {
          "type": "array",
          "items": { "$ref": "common.json#/$defs/diagnostics_entry" }
        },
        "validation": { "$ref": "common.json#/$defs/validation_section" },
        "errors": {
          "type": "array",
          "items": { "$ref": "common.json#/$defs/diagnostics_entry" }
        }
      }
    },
    "logical_block": {
      "type": "object",
      "required": ["block_id", "purpose", "rationale", "source_sql_ref", "confidence"],
      "properties": {
        "block_id": {
          "type": "string",
          "description": "Format: <sequence>_<operation_class>_<target_hint> (e.g. 01_extract_sales_stage)."
        },
        "purpose": { "type": "string" },
        "rationale": { "type": "array", "items": { "type": "string" } },
        "source_sql_ref": { "$ref": "#/$defs/source_sql_ref" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "split_point": {
      "type": "object",
      "required": ["split_after_block_id", "proposed_model_name", "rationale", "confidence"],
      "properties": {
        "split_after_block_id": { "type": "string" },
        "proposed_model_name": {
          "type": "string",
          "description": "Format: int_<entity>_<purpose>, lowercase snake_case."
        },
        "rationale": { "type": "array", "items": { "type": "string" } },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "source_sql_ref": {
      "type": "object",
      "required": ["statement_indices"],
      "properties": {
        "statement_indices": { "type": "array", "items": { "type": "integer", "minimum": 0 } },
        "line_span": {
          "type": "object",
          "required": ["start", "end"],
          "properties": {
            "start": { "type": "integer" },
            "end": { "type": "integer" }
          }
        }
      }
    }
  }
}
