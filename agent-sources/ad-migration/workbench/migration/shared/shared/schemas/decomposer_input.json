{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DecomposerInput",
  "description": "Input contract for the decomposer agent. Produces SQL decomposition proposals for dbt migration.",
  "type": "object",
  "required": ["schema_version", "run_id", "items"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "run_id": { "type": "string", "format": "uuid" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["item_id", "writer"],
        "properties": {
          "item_id": { "type": "string", "description": "Fully qualified table name: <schema>.<table>." },
          "writer": { "type": "string", "description": "Fully qualified writer procedure name." }
        }
      },
      "minItems": 1
    }
  }
}
