{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ProfilerInput",
  "description": "Input contract for the profiler agent. Produces migration profile candidates for each table.",
  "type": "object",
  "required": ["schema_version", "run_id", "ddl_path", "items"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "run_id": { "type": "string", "format": "uuid" },
    "ddl_path": {
      "type": "string",
      "description": "Absolute path to the DDL artifacts directory."
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["item_id", "selected_writer"],
        "properties": {
          "item_id": { "type": "string", "description": "Fully qualified table name: <schema>.<table>." },
          "selected_writer": { "type": "string", "description": "Fully qualified procedure name selected by scoping agent." }
        }
      },
      "minItems": 1
    }
  }
}
