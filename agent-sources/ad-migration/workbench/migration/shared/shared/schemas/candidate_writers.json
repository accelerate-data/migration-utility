{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CandidateWriters",
  "description": "Output contract for the scoping agent. Contains per-table writer discovery and selection results.",
  "type": "object",
  "required": ["schema_version", "run_id", "results", "summary"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "run_id": { "type": "string", "format": "uuid" },
    "results": {
      "type": "array",
      "items": { "$ref": "#/$defs/scope_result" }
    },
    "summary": { "$ref": "#/$defs/scope_summary" }
  },
  "$defs": {
    "scope_result": {
      "type": "object",
      "required": ["item_id", "status", "analysis", "candidate_writers", "warnings", "validation", "errors"],
      "properties": {
        "item_id": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["resolved", "ambiguous_multi_writer", "partial", "no_writer_found", "error"]
        },
        "analysis": {
          "type": "string",
          "enum": ["deterministic", "claude_assisted"],
          "description": "deterministic when all candidates came from AST analysis; claude_assisted when any candidate required LLM reasoning."
        },
        "selected_writer": { "type": "string", "description": "Present only when status is resolved." },
        "candidate_writers": {
          "type": "array",
          "items": { "$ref": "#/$defs/candidate_writer" }
        },
        "warnings": {
          "type": "array",
          "items": { "$ref": "common.json#/$defs/diagnostics_entry" }
        },
        "validation": { "$ref": "common.json#/$defs/validation_section" },
        "errors": {
          "type": "array",
          "items": { "$ref": "common.json#/$defs/diagnostics_entry" }
        }
      }
    },
    "candidate_writer": {
      "type": "object",
      "required": ["procedure_name", "write_type", "call_path", "rationale", "confidence", "analysis"],
      "properties": {
        "procedure_name": { "type": "string" },
        "write_type": {
          "type": "string",
          "enum": ["direct", "indirect", "read_only"]
        },
        "write_operations": {
          "type": "array",
          "items": { "type": "string" },
          "description": "DML operations detected (INSERT, UPDATE, DELETE, MERGE, TRUNCATE, etc.)."
        },
        "call_path": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Procedure call chain from candidate to the target table write."
        },
        "dependencies": {
          "type": "object",
          "description": "Transitively resolved base tables, views, and functions the writer depends on. Populated on selected writer for resolved items.",
          "properties": {
            "tables": { "type": "array", "items": { "type": "string" } },
            "views": { "type": "array", "items": { "type": "string" } },
            "functions": { "type": "array", "items": { "type": "string" } }
          }
        },
        "rationale": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "analysis": {
          "type": "string",
          "enum": ["deterministic", "claude_assisted"]
        }
      }
    },
    "scope_summary": {
      "type": "object",
      "required": ["total", "resolved", "ambiguous_multi_writer", "no_writer_found", "partial", "error"],
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "resolved": { "type": "integer", "minimum": 0 },
        "ambiguous_multi_writer": { "type": "integer", "minimum": 0 },
        "no_writer_found": { "type": "integer", "minimum": 0 },
        "partial": { "type": "integer", "minimum": 0 },
        "error": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
