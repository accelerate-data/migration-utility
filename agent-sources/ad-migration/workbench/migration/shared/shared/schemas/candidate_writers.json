{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CandidateWriters",
  "description": "Output contract for the scoping agent. Contains per-table writer discovery and selection results.",
  "type": "object",
  "required": ["schema_version", "run_id", "results", "summary"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "run_id": { "type": "string", "format": "uuid" },
    "results": {
      "type": "array",
      "items": { "$ref": "#/$defs/scope_result" }
    },
    "summary": { "$ref": "#/$defs/scope_summary" }
  },
  "$defs": {
    "scope_result": {
      "type": "object",
      "required": ["item_id", "status", "candidate_writers", "warnings", "validation", "errors"],
      "properties": {
        "item_id": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["resolved", "ambiguous_multi_writer", "no_writer_found", "error"]
        },
        "selected_writer": { "type": "string", "description": "Present only when status is resolved." },
        "candidate_writers": {
          "type": "array",
          "items": { "$ref": "#/$defs/candidate_writer" }
        },
        "warnings": {
          "type": "array",
          "items": { "$ref": "common.json#/$defs/diagnostics_entry" }
        },
        "validation": { "$ref": "common.json#/$defs/validation_section" },
        "errors": {
          "type": "array",
          "items": { "$ref": "common.json#/$defs/diagnostics_entry" }
        }
      }
    },
    "candidate_writer": {
      "type": "object",
      "required": ["procedure_name", "rationale"],
      "properties": {
        "procedure_name": { "type": "string" },
        "dependencies": {
          "type": "object",
          "description": "Read/write targets from discover show refs. Populated for resolved items.",
          "properties": {
            "tables": { "type": "array", "items": { "type": "string" } },
            "views": { "type": "array", "items": { "type": "string" } },
            "functions": { "type": "array", "items": { "type": "string" } }
          }
        },
        "rationale": {
          "type": "string",
          "description": "Why this procedure was identified as a writer."
        },
        "llm_analysis": {
          "type": "object",
          "description": "Present when classification is claude_assisted. The scoping agent read raw_ddl and determined refs that the catalog could not resolve. Consumed by downstream agents to avoid re-analysing the same proc.",
          "properties": {
            "reads_from": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Tables/views the proc reads from, as determined by LLM."
            },
            "writes_to": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Tables the proc writes to, as determined by LLM."
            },
            "statements": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "action": { "type": "string", "enum": ["migrate", "skip"] },
                  "sql": { "type": "string" }
                }
              },
              "description": "Statement-level classification produced by the LLM."
            },
            "rationale": {
              "type": "string",
              "description": "LLM reasoning for the analysis — what it found in the raw_ddl."
            }
          }
        }
      }
    },
    "scope_summary": {
      "type": "object",
      "required": ["total", "resolved", "ambiguous_multi_writer", "no_writer_found", "error"],
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "resolved": { "type": "integer", "minimum": 0 },
        "ambiguous_multi_writer": { "type": "integer", "minimum": 0 },
        "no_writer_found": { "type": "integer", "minimum": 0 },
        "error": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
