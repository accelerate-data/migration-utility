{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FunctionCatalog",
  "description": "Per-function catalog file produced by setup-ddl. Contains outbound references and inbound dependents.",
  "type": "object",
  "required": ["function", "references", "referenced_by"],
  "properties": {
    "function": {
      "type": "string",
      "description": "Fully qualified function name: <schema>.<function>"
    },
    "references": {
      "type": "object",
      "description": "Outbound: what this function depends on.",
      "required": ["tables", "views", "functions"],
      "properties": {
        "tables": { "$ref": "common.json#/$defs/scoped_ref_list" },
        "views": { "$ref": "common.json#/$defs/scoped_ref_list" },
        "functions": { "$ref": "common.json#/$defs/scoped_ref_list" }
      }
    },
    "referenced_by": {
      "type": "object",
      "description": "Inbound: what references this function.",
      "required": ["procedures", "views", "functions"],
      "properties": {
        "procedures": { "$ref": "common.json#/$defs/scoped_ref_list" },
        "views": { "$ref": "common.json#/$defs/scoped_ref_list" },
        "functions": { "$ref": "common.json#/$defs/scoped_ref_list" }
      }
    }
  }
}
