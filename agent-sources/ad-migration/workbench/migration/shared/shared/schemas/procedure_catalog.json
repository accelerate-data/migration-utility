{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ProcedureCatalog",
  "description": "Per-procedure catalog file produced by setup-ddl. Contains outbound references and inbound callers.",
  "type": "object",
  "required": ["references"],
  "properties": {
    "params": {
      "type": "array",
      "description": "Procedure parameters from sys.parameters. Populated by export_ddl.",
      "items": {
        "type": "object",
        "required": ["name", "sql_type"],
        "properties": {
          "name": { "type": "string", "description": "Parameter name including @, e.g. @CustomerId" },
          "sql_type": { "type": "string" },
          "is_output": { "type": "boolean" },
          "has_default": { "type": "boolean" }
        }
      }
    },
    "needs_llm": {
      "type": "boolean",
      "description": "True when body contains EXEC(@var), TRY/CATCH, WHILE, or IF/ELSE. Set by body scan during export."
    },
    "needs_enrich": {
      "type": "boolean",
      "description": "True when body contains SELECT INTO, TRUNCATE, or static EXEC chains. Flipped to false by catalog-enrich."
    },
    "references": {
      "type": "object",
      "description": "Outbound: what this procedure depends on.",
      "required": ["tables", "views", "functions", "procedures"],
      "properties": {
        "tables": { "$ref": "common.json#/$defs/scoped_ref_list" },
        "views": { "$ref": "common.json#/$defs/scoped_ref_list" },
        "functions": { "$ref": "common.json#/$defs/scoped_ref_list" },
        "procedures": { "$ref": "common.json#/$defs/scoped_ref_list" }
      }
    },
    "referenced_by": {
      "type": "object",
      "description": "Inbound: what calls this procedure.",
      "required": ["procedures"],
      "properties": {
        "procedures": { "$ref": "common.json#/$defs/scoped_ref_list" }
      }
    }
  }
}
