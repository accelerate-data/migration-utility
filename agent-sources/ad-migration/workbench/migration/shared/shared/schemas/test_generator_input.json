{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TestGeneratorInput",
  "description": "Input contract for the test generator agent. Receives planner output unchanged.",
  "type": "object",
  "required": ["schema_version", "run_id", "items"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "run_id": { "type": "string", "format": "uuid" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["item_id", "answers", "decomposition", "plan"],
        "properties": {
          "item_id": { "type": "string", "description": "Fully qualified table name: <schema>.<table>." },
          "answers": { "$ref": "planner_input.json#/$defs/answers" },
          "decomposition": { "$ref": "planner_input.json#/$defs/decomposition" },
          "plan": { "$ref": "#/$defs/plan" }
        }
      },
      "minItems": 1
    }
  },
  "$defs": {
    "plan": {
      "type": "object",
      "required": ["materialization", "documentation"],
      "properties": {
        "materialization": {
          "type": "string",
          "enum": ["incremental", "table", "snapshot"]
        },
        "schema_tests": { "type": "object" },
        "documentation": {
          "type": "object",
          "required": ["model_name"],
          "properties": {
            "model_name": { "type": "string" },
            "model_description": { "type": "string" },
            "column_descriptions": { "type": "array" },
            "business_definitions": { "type": "array" },
            "tags": { "type": "array", "items": { "type": "string" } },
            "owner": { "type": "string" }
          }
        }
      }
    }
  }
}
