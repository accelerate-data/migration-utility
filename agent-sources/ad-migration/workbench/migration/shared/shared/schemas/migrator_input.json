{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MigratorInput",
  "description": "Input contract for the migrator agent. Receives planner output merged with test generator unit_tests per item.",
  "type": "object",
  "required": ["schema_version", "run_id", "items"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "run_id": { "type": "string", "format": "uuid" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["item_id", "answers", "decomposition", "plan", "unit_tests"],
        "properties": {
          "item_id": { "type": "string", "description": "Fully qualified table name: <schema>.<table>." },
          "answers": { "$ref": "planner_input.json#/$defs/answers" },
          "decomposition": { "$ref": "planner_input.json#/$defs/decomposition" },
          "plan": { "$ref": "#/$defs/plan" },
          "unit_tests": {
            "type": "array",
            "items": { "$ref": "#/$defs/unit_test" }
          }
        }
      },
      "minItems": 1
    }
  },
  "$defs": {
    "plan": {
      "type": "object",
      "required": ["materialization", "schema_tests", "documentation"],
      "properties": {
        "materialization": {
          "type": "string",
          "enum": ["incremental", "table", "snapshot"]
        },
        "schema_tests": {
          "type": "object",
          "required": [
            "entity_integrity_tests",
            "referential_integrity_tests",
            "domain_validity_tests",
            "incremental_recency_tests",
            "classification_semantic_tests",
            "pii_governance_checks"
          ],
          "properties": {
            "entity_integrity_tests": { "type": "array" },
            "referential_integrity_tests": { "type": "array" },
            "domain_validity_tests": { "type": "array" },
            "incremental_recency_tests": { "type": "array" },
            "classification_semantic_tests": { "type": "array" },
            "pii_governance_checks": { "type": "array" }
          }
        },
        "documentation": {
          "type": "object",
          "required": ["model_name", "model_description"],
          "properties": {
            "model_name": { "type": "string" },
            "model_description": { "type": "string" },
            "column_descriptions": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["column", "description"],
                "properties": {
                  "column": { "type": "string" },
                  "description": { "type": "string" }
                }
              }
            },
            "business_definitions": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["term", "definition"],
                "properties": {
                  "term": { "type": "string" },
                  "definition": { "type": "string" }
                }
              }
            },
            "tags": { "type": "array", "items": { "type": "string" } },
            "owner": { "type": "string" }
          }
        }
      }
    },
    "unit_test": {
      "type": "object",
      "required": ["name", "model", "given", "expect"],
      "properties": {
        "name": { "type": "string", "description": "Test name — convention: test_<load_pattern>_<scenario_description>." },
        "model": { "type": "string", "description": "dbt model name from plan.documentation.model_name." },
        "given": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["input", "rows"],
            "properties": {
              "input": { "type": "string", "description": "dbt ref() or source() expression identifying the relation." },
              "rows": {
                "type": "array",
                "items": { "type": "object" },
                "minItems": 1
              }
            }
          },
          "minItems": 1
        },
        "expect": {
          "type": "object",
          "required": ["rows"],
          "properties": {
            "rows": {
              "type": "array",
              "items": { "type": "object" },
              "minItems": 1
            }
          }
        }
      }
    }
  }
}
