{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ViewCatalog",
  "description": "Per-view catalog file produced by setup-ddl. Contains outbound references and inbound dependents.",
  "type": "object",
  "required": ["view", "references", "referenced_by"],
  "properties": {
    "view": {
      "type": "string",
      "description": "Fully qualified view name: <schema>.<view>"
    },
    "references": {
      "type": "object",
      "description": "Outbound: what this view depends on.",
      "required": ["tables", "views", "functions"],
      "properties": {
        "tables": { "$ref": "#/$defs/scoped_ref_list" },
        "views": { "$ref": "#/$defs/scoped_ref_list" },
        "functions": { "$ref": "#/$defs/scoped_ref_list" }
      }
    },
    "referenced_by": {
      "type": "object",
      "description": "Inbound: what references this view.",
      "required": ["procedures", "views", "functions"],
      "properties": {
        "procedures": { "$ref": "#/$defs/scoped_ref_list" },
        "views": { "$ref": "#/$defs/scoped_ref_list" },
        "functions": { "$ref": "#/$defs/scoped_ref_list" }
      }
    }
  },
  "$defs": {
    "scoped_ref_list": {
      "type": "object",
      "required": ["in_scope", "out_of_scope"],
      "properties": {
        "in_scope": { "type": "array", "items": { "$ref": "#/$defs/in_scope_ref" } },
        "out_of_scope": { "type": "array", "items": { "$ref": "#/$defs/out_of_scope_ref" } }
      }
    },
    "in_scope_ref": {
      "type": "object",
      "required": ["schema", "name"],
      "properties": {
        "schema": { "type": "string" },
        "name": { "type": "string" },
        "is_selected": { "type": "boolean" },
        "is_updated": { "type": "boolean" },
        "is_schema_bound": { "type": "boolean" },
        "is_caller_dependent": { "type": "boolean" },
        "is_ambiguous": { "type": "boolean" },
        "detection": { "type": "string", "enum": ["dmf", "ast_scan"] },
        "columns": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": { "type": "string" },
              "is_selected": { "type": "boolean" },
              "is_updated": { "type": "boolean" }
            }
          }
        }
      }
    },
    "out_of_scope_ref": {
      "type": "object",
      "required": ["schema", "name", "reason"],
      "properties": {
        "schema": { "type": "string" },
        "name": { "type": "string" },
        "database": { "type": "string" },
        "server": { "type": ["string", "null"] },
        "reason": { "type": "string" }
      }
    }
  }
}
