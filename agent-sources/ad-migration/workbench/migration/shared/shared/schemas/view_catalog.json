{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ViewCatalog",
  "description": "Per-view catalog file produced by setup-ddl. Contains outbound references and inbound dependents.",
  "type": "object",
  "required": ["schema", "name", "references", "referenced_by"],
  "properties": {
    "schema": { "type": "string", "description": "Schema name, e.g. silver" },
    "name": { "type": "string", "description": "Object name, e.g. vw_CustomerSales" },
    "references": {
      "type": "object",
      "description": "Outbound: what this view depends on.",
      "required": ["tables", "views", "functions"],
      "properties": {
        "tables": { "$ref": "common.json#/$defs/scoped_ref_list" },
        "views": { "$ref": "common.json#/$defs/scoped_ref_list" },
        "functions": { "$ref": "common.json#/$defs/scoped_ref_list" }
      }
    },
    "referenced_by": {
      "type": "object",
      "description": "Inbound: what references this view.",
      "required": ["procedures", "views", "functions"],
      "properties": {
        "procedures": { "$ref": "common.json#/$defs/scoped_ref_list" },
        "views": { "$ref": "common.json#/$defs/scoped_ref_list" },
        "functions": { "$ref": "common.json#/$defs/scoped_ref_list" }
      }
    }
  }
}
