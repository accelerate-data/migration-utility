      "action": "migrate",
      "sql": "INSERT INTO CHANNEL_SALES_SUMMARY (CHANNEL_ID, CHANNEL_DESC, TOTAL_AMOUNT, TIER, UPDATED_AT) WITH channel_totals AS (SELECT c.CHANNEL_ID, c.CHANNEL_DESC, SUM(s.AMOUNT_SOLD) AS TOTAL_AMOUNT FROM CHANNELS c JOIN SALES s ON s.CHANNEL_ID = c.CHANNEL_ID GROUP BY c.CHANNEL_ID, c.CHANNEL_DESC) SELECT CHANNEL_ID, CHANNEL_DESC, TOTAL_AMOUNT, 'UNKNOWN', SYSDATE FROM channel_totals"
    },
