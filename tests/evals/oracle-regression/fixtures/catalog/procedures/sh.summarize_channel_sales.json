      "sql": "MERGE INTO CHANNEL_SALES_SUMMARY tgt USING (SELECT rec.CHANNEL_ID AS CHANNEL_ID, v_tier AS TIER FROM DUAL) src ON (tgt.CHANNEL_ID = src.CHANNEL_ID) WHEN MATCHED THEN UPDATE SET tgt.TIER = src.TIER, tgt.UPDATED_AT = SYSDATE"
