  "statements": [
    {
      "type": "Merge",
      "action": "migrate",
      "sql": "MERGE silver.DimCustomer AS tgt USING (SELECT CAST(c.CustomerID AS NVARCHAR(15)) AS CustomerAlternateKey, p.FirstName, p.MiddleName, p.LastName, p.Title, NULL AS Gender, NULL AS MaritalStatus, p.EmailPromotion FROM bronze.Customer c JOIN bronze.Person p ON c.PersonID = p.BusinessEntityID) AS src ON tgt.CustomerAlternateKey = src.CustomerAlternateKey WHEN MATCHED THEN UPDATE SET tgt.FirstName = src.FirstName, tgt.MiddleName = src.MiddleName, tgt.LastName = src.LastName, tgt.Title = src.Title, tgt.EmailPromotion = src.EmailPromotion WHEN NOT MATCHED BY TARGET THEN INSERT (CustomerAlternateKey, FirstName, MiddleName, LastName, Title, Gender, MaritalStatus, EmailPromotion) VALUES (src.CustomerAlternateKey, src.FirstName, src.MiddleName, src.LastName, src.Title, src.Gender, src.MaritalStatus, src.EmailPromotion)"
    }
