  "coverage": "complete",
  "branch_manifest": [
    {
      "id": "insert_happy_path",
      "statement_index": 0,
      "description": "INNER JOIN matches — single header + single detail row inserts one fact row with all fields populated including ShipDate",
      "scenarios": [
        "test_insert_single_line_all_fields"
      ]
    },
    {
      "id": "empty_source",
      "statement_index": 0,
      "description": "Both source tables empty — INSERT produces no rows",
      "scenarios": [
        "test_insert_empty_source"
      ]
    },
    {
      "id": "join_miss_no_header",
      "statement_index": 0,
      "description": "Detail row exists but no matching header (INNER JOIN) — detail is excluded from output",
      "scenarios": [
        "test_insert_join_miss_no_header"
      ]
    },
    {
      "id": "multi_line_tax_freight_distribution",
      "statement_index": 0,
      "description": "One header + multiple detail rows — TaxAmt and Freight are divided equally across lines via COUNT(*) OVER (PARTITION BY SalesOrderID)",
      "scenarios": [
        "test_insert_multi_line_tax_freight_split"
      ]
    },
    {
      "id": "null_shipdate",
      "statement_index": 0,
      "description": "Header has NULL ShipDate — nullable column flows through to target ShipDate as NULL",
      "scenarios": [
        "test_insert_null_shipdate"
      ]
    },
    {
      "id": "null_territory",
      "statement_index": 0,
      "description": "Header has NULL TerritoryID — nullable SalesTerritoryKey flows through as NULL",
      "scenarios": [
        "test_insert_null_territory"
      ]
    },
    {
      "id": "detail_id_mod127_zero",
      "statement_index": 0,
      "description": "SalesOrderDetailID = 127 — modulo expression 127 % 127 = 0, SalesOrderLineNumber is cast to TINYINT value 0",
      "scenarios": [
        "test_insert_detail_id_mod127_zero"
      ]
    }
  ],
