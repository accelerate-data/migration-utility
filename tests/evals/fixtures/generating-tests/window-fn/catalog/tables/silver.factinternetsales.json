    "writer": "silver.usp_stage_factinternetsales",
    "classification": {
      "resolved_kind": "fact_transaction",
      "rationale": "Table has transactional grain — one row per sales order line (composite natural-key PK of SalesOrderNumber + SalesOrderLineNumber) with additive measures. The TRUNCATE + INSERT write pattern is a full-reload staging strategy; the absence of a snapshot_date column eliminates fact_periodic_snapshot, and all three date columns (OrderDate, DueDate, ShipDate) are populated simultaneously from a single JOIN rather than updated individually, eliminating fact_accumulating_snapshot.",
      "source": "llm"
    },
    "primary_key": {
      "columns": [
        "SalesOrderNumber",
        "SalesOrderLineNumber"
      ],
      "primary_key_type": "composite",
      "source": "catalog",
      "rationale": "Declared as PK_FactInternetSales in the catalog. Composite of the business order number (NVARCHAR) and order line number (TINYINT) forming a natural composite key at sales order line grain."
    },
    "natural_key": {
      "columns": [
        "SalesOrderNumber",
        "SalesOrderLineNumber"
      ],
      "source": "llm",
      "rationale": "No IDENTITY column in auto_increment_columns and no NEWID() or surrogate assignment in the proc body. SalesOrderNumber is an NVARCHAR business key sourced directly from bronze.SalesOrderHeader with no _sk suffix."
    },
