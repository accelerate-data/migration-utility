#!/bin/sh
# Prevent committing secrets: Anthropic API key or SA_PASSWORD in .mcp.json

# Block Anthropic API keys
ANT_KEY_PAT="sk-ant"; ANT_KEY_PAT="${ANT_KEY_PAT}-"
if git diff --cached --name-only | xargs grep -l "$ANT_KEY_PAT" 2>/dev/null | grep -q .; then
  echo "ERROR: Anthropic API key detected in staged files." >&2
  echo "Remove the key before committing." >&2
  git diff --cached --name-only | xargs grep -l "$ANT_KEY_PAT" 2>/dev/null | while read f; do
    echo "  $f" >&2
  done
  exit 1
fi

# Block SA_PASSWORD in .mcp.json

if git diff --cached --name-only | grep -q "^\.mcp\.json$"; then
  password=$(git show :0:.mcp.json \
    | python3 -c "import json,sys; d=json.load(sys.stdin); \
      print(d.get('mcpServers',{}).get('mssql',{}).get('env',{}).get('SA_PASSWORD',''))" \
    2>/dev/null)
  if [ -n "$password" ]; then
    echo "ERROR: SA_PASSWORD is set in .mcp.json — clear it before committing."
    exit 1
  fi
fi
