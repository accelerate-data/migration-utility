{
  "mcpServers": {
    "mssql": {
      "command": "toolbox",
      "args": [
        "--tools-file",
        ".claude/mcp/tools.yaml",
        "--stdio"
      ],
      "env": {
        "_comment": "Set SA_PASSWORD in your environment before running: export SA_PASSWORD=your_password",
        "MSSQL_HOST": "127.0.0.1",
        "MSSQL_PORT": "1433",
        "MSSQL_DB": "AdventureWorks2022"
      }
    },
    "oracle": {
      "command": "/opt/homebrew/Caskroom/sqlcl/26.1.0.086.1709/sqlcl/bin/sql",
      "args": [
        "-mcp",
        "sh/sh@localhost:1521/FREEPDB1"
      ]
    }
  }
}
