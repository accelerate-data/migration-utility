# Local environment variables for development
export CLAUDE_PLUGIN_ROOT="${PWD}"

export MSSQL_DRIVER="${MSSQL_DRIVER:-ODBC Driver 18 for SQL Server}"
export MSSQL_HOST="${MSSQL_HOST:-127.0.0.1}"
export MSSQL_PORT="${MSSQL_PORT:-1433}"
export MSSQL_DB="${MSSQL_DB:-AdventureWorks2022}"
export ORACLE_USER="${ORACLE_USER:-sh}"
export ORACLE_DSN="${ORACLE_DSN:-localhost:1521/FREEPDB1}"
export SQLCL_BIN="${SQLCL_BIN:-$(command -v sql || command -v sqlcl || printf 'sql')}"

dotenv
