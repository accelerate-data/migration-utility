# Local environment variables for development

export CLAUDE_PLUGIN_ROOT="${PWD}"

if [[ "${MIGRATION_UTILITY_SKIP_LOCAL_DEP_SYNC:-0}" != "1" ]]; then
  if ! python3 "${PWD}/scripts/bootstrap_repo_local_env.py" --repo-root "${PWD}" --quiet ensure all; then
    echo "repo-local dependency bootstrap failed; rerun ./scripts/worktree.sh <branch> or set MIGRATION_UTILITY_SKIP_LOCAL_DEP_SYNC=1 to bypass temporarily." >&2
    return 1
  fi
fi

# SQL Server

export SOURCE_MSSQL_HOST=localhost
export SOURCE_MSSQL_PORT=1433
export SOURCE_MSSQL_DB=AdventureWorks2022
export SOURCE_MSSQL_SCHEMA=MigrationTest
export SOURCE_MSSQL_USER=migrationtest_reader

export TARGET_MSSQL_HOST=localhost
export TARGET_MSSQL_PORT=1433
export TARGET_MSSQL_DB=MigrationTarget
export TARGET_MSSQL_USER=sa

export SANDBOX_MSSQL_HOST=localhost
export SANDBOX_MSSQL_PORT=1433
export SANDBOX_MSSQL_USER=sa

# Oracle

export SOURCE_ORACLE_HOST=localhost
export SOURCE_ORACLE_PORT=1521
export SOURCE_ORACLE_SERVICE=FREEPDB1
export SOURCE_ORACLE_SCHEMA=MIGRATIONTEST
export SOURCE_ORACLE_USER=MIGRATIONTEST

export TARGET_ORACLE_HOST=localhost
export TARGET_ORACLE_PORT=1521
export TARGET_ORACLE_SERVICE=FREEPDB1
export TARGET_ORACLE_USER=system

export SANDBOX_ORACLE_HOST=localhost
export SANDBOX_ORACLE_PORT=1521
export SANDBOX_ORACLE_SERVICE=FREE
export SANDBOX_ORACLE_USER=sys

dotenv
