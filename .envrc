# Local environment variables for development
export CLAUDE_PLUGIN_ROOT="${PWD}"

 # SQL Server

# Direct SQL Server integration fixture helpers
export MSSQL_HOST=localhost
export MSSQL_PORT=1433
export MSSQL_DB=AdventureWorks2022
export MSSQL_USER=sa
export MSSQL_DRIVER='ODBC Driver 18 for SQL Server'

# CLI/setup-source integration paths
export SOURCE_MSSQL_HOST="$MSSQL_HOST"
export SOURCE_MSSQL_PORT="$MSSQL_PORT"
export SOURCE_MSSQL_DB="$MSSQL_DB"
export SOURCE_MSSQL_USER="$MSSQL_USER"
export SOURCE_MSSQL_PASSWORD="$SA_PASSWORD"

# Needed when testing setup-target / setup-sandbox commands
export TARGET_MSSQL_HOST="$MSSQL_HOST"
export TARGET_MSSQL_PORT="$MSSQL_PORT"
export TARGET_MSSQL_DB="$MSSQL_DB"
export TARGET_MSSQL_USER="$MSSQL_USER"
export TARGET_MSSQL_PASSWORD="$SA_PASSWORD"

export SANDBOX_MSSQL_HOST="$MSSQL_HOST"
export SANDBOX_MSSQL_PORT="$MSSQL_PORT"
export SANDBOX_MSSQL_USER="$MSSQL_USER"
export SANDBOX_MSSQL_PASSWORD="$SA_PASSWORD"

# Oracle

# Direct Oracle integration fixture helpers
export ORACLE_HOST=localhost
export ORACLE_PORT=1521
export ORACLE_SERVICE=FREEPDB1
export ORACLE_ADMIN_USER=sys
export ORACLE_SCHEMA=MIGRATIONTEST

# Oracle extract path used by shared db_connect.py
export ORACLE_DSN="${ORACLE_HOST}:${ORACLE_PORT}/${ORACLE_SERVICE}"

export SOURCE_ORACLE_HOST="$ORACLE_HOST"
export SOURCE_ORACLE_PORT="$ORACLE_PORT"
export SOURCE_ORACLE_SERVICE="$ORACLE_SERVICE"
export SOURCE_ORACLE_USER="$ORACLE_SCHEMA"
export SOURCE_ORACLE_PASSWORD="$ORACLE_PWD"
  
export TARGET_ORACLE_HOST="$ORACLE_HOST"
export TARGET_ORACLE_PORT="$ORACLE_PORT"
export TARGET_ORACLE_SERVICE="$ORACLE_SERVICE"
export TARGET_ORACLE_USER="$ORACLE_SCHEMA"
export TARGET_ORACLE_PASSWORD="$ORACLE_PWD"

export SANDBOX_ORACLE_HOST="$ORACLE_HOST"
export SANDBOX_ORACLE_PORT="$ORACLE_PORT"
export SANDBOX_ORACLE_SERVICE="$ORACLE_SERVICE"
export SANDBOX_ORACLE_USER="$ORACLE_ADMIN_USER"
export SANDBOX_ORACLE_PASSWORD="$ORACLE_PWD"

dotenv
